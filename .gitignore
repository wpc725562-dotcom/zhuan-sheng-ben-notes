# Obsidian workspace / local state (device-specific)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/workspaces.json
.obsidian/cache
.obsidian/plugins/*/data.json

# Trash / temp
.obsidian-mcp-trash/
.trash/
*.tmp
*.temp
~*

# Local learning DB / scripts not part of notes
mtool_learning_state.db
*.db

# OS
.DS_Store
Thumbs.db
desktop.ini

# Large media (keep notes only)
*.mp4
*.mkv
*.avi
*.mov
*.zip
*.rar
*.7z

# Node / VitePress
node_modules/
docs/.vitepress/dist/
docs/.vitepress/cache/
package-lock.json.bak
*.log
.npm/

# Large local study materials (keep on disk, don't push)
*.pdf
资料/英语真题原卷/_extract/
资料/英语真题原卷/_by_year/
# keep small helper scripts & md under 资料/
!资料/**/*.md
!资料/**/*.py
# site-embedded exam PDFs (split by year for the blog)
!docs/public/papers/**/*.pdf
__pycache__/
